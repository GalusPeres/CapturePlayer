# Normalize line endings: store as LF in git and check out as LF on every
# platform, so the prettier `endOfLine: lf` rule passes on Windows too.
* text=auto eol=lf

# Treat binary assets as binary (never touch their bytes).
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
